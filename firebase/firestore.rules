rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownerEmail() {
      return signedIn() && request.auth.token.email in ['vovapotaychuk@gmail.com'];
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function currentRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.role
        : 'player';
    }

    function currentRegion() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.gameProfile.region
        : '';
    }

    function currentAlliance() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.gameProfile.alliance
        : '';
    }

    function currentRank() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.gameProfile.rank
        : '';
    }

    function isSameRegion(regionId) {
      return signedIn() && currentRegion() == regionId;
    }

    function currentUserExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRegionAccess(regionId) {
      return currentUserExists()
        && (currentRegion() == regionId
          || (currentUserDoc().data.keys().hasAny(['regionAccess']) && regionId in currentUserDoc().data.regionAccess));
    }

    function currentRegionRole(regionId) {
      return ownerEmail() ? 'admin'
        : currentRole() in ['admin', 'moderator'] ? currentRole()
        : isSameRegion(regionId) ? currentRole()
        : (currentUserExists()
          && currentUserDoc().data.keys().hasAny(['regionRoles'])
          && currentUserDoc().data.regionRoles.keys().hasAny([regionId])
            ? currentUserDoc().data.regionRoles[regionId]
            : 'player');
    }

    function regionRolesWriteSafe() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['regionRoles'])
        || (
          request.resource.data.keys().hasAny(['regionRoles'])
          && (
            (resource.data.keys().hasAny(['regionRoles']) && request.resource.data.regionRoles == resource.data.regionRoles)
            || (!resource.data.keys().hasAny(['regionRoles']) && request.resource.data.regionRoles.keys().size() == 0)
          )
        );
    }

    function requestFarmsIsList() {
      return request.resource.data.keys().hasAny(['farms']) && request.resource.data.farms is list;
    }

    function requestFarm(index) {
      return requestFarmsIsList() && request.resource.data.farms.size() > index
        ? request.resource.data.farms[index]
        : {};
    }

    function requestFarmRegion(index) {
      return requestFarm(index).keys().hasAny(['region']) ? requestFarm(index).region : '';
    }

    function requestFarmAlliance(index) {
      return requestFarm(index).keys().hasAny(['alliance']) ? requestFarm(index).alliance : '';
    }

    function profileRegionAllowList() {
      return [
        request.resource.data.keys().hasAny(['region']) ? request.resource.data.region : '',
        request.resource.data.keys().hasAny(['gameProfile']) && request.resource.data.gameProfile.keys().hasAny(['region']) ? request.resource.data.gameProfile.region : '',
        requestFarmRegion(0), requestFarmRegion(1), requestFarmRegion(2), requestFarmRegion(3), requestFarmRegion(4),
        requestFarmRegion(5), requestFarmRegion(6), requestFarmRegion(7), requestFarmRegion(8), requestFarmRegion(9),
        requestFarmRegion(10), requestFarmRegion(11), requestFarmRegion(12), requestFarmRegion(13), requestFarmRegion(14),
        requestFarmRegion(15), requestFarmRegion(16), requestFarmRegion(17), requestFarmRegion(18), requestFarmRegion(19)
      ];
    }

    function profileAllianceAllowList() {
      return [
        ((request.resource.data.keys().hasAny(['region']) ? request.resource.data.region : '') + ':' + (request.resource.data.keys().hasAny(['alliance']) ? request.resource.data.alliance : '')),
        ((request.resource.data.keys().hasAny(['gameProfile']) && request.resource.data.gameProfile.keys().hasAny(['region']) ? request.resource.data.gameProfile.region : '') + ':' + (request.resource.data.keys().hasAny(['gameProfile']) && request.resource.data.gameProfile.keys().hasAny(['alliance']) ? request.resource.data.gameProfile.alliance : '')),
        requestFarmRegion(0) + ':' + requestFarmAlliance(0), requestFarmRegion(1) + ':' + requestFarmAlliance(1),
        requestFarmRegion(2) + ':' + requestFarmAlliance(2), requestFarmRegion(3) + ':' + requestFarmAlliance(3),
        requestFarmRegion(4) + ':' + requestFarmAlliance(4), requestFarmRegion(5) + ':' + requestFarmAlliance(5),
        requestFarmRegion(6) + ':' + requestFarmAlliance(6), requestFarmRegion(7) + ':' + requestFarmAlliance(7),
        requestFarmRegion(8) + ':' + requestFarmAlliance(8), requestFarmRegion(9) + ':' + requestFarmAlliance(9),
        requestFarmRegion(10) + ':' + requestFarmAlliance(10), requestFarmRegion(11) + ':' + requestFarmAlliance(11),
        requestFarmRegion(12) + ':' + requestFarmAlliance(12), requestFarmRegion(13) + ':' + requestFarmAlliance(13),
        requestFarmRegion(14) + ':' + requestFarmAlliance(14), requestFarmRegion(15) + ':' + requestFarmAlliance(15),
        requestFarmRegion(16) + ':' + requestFarmAlliance(16), requestFarmRegion(17) + ':' + requestFarmAlliance(17),
        requestFarmRegion(18) + ':' + requestFarmAlliance(18), requestFarmRegion(19) + ':' + requestFarmAlliance(19)
      ];
    }

    function profileAccessFieldsSafe() {
      return request.resource.data.keys().hasAny(['regionAccess'])
        && request.resource.data.keys().hasAny(['allianceAccess'])
        && request.resource.data.regionAccess is list
        && request.resource.data.allianceAccess is list
        && request.resource.data.regionAccess.hasOnly(profileRegionAllowList())
        && request.resource.data.allianceAccess.hasOnly(profileAllianceAllowList())
        && regionRolesWriteSafe();
    }

    function canReviewRoleRequests() {
      return ownerEmail() || isAdmin() || isModerator();
    }

    function isAdmin() {
      return ownerEmail() || currentRole() == 'admin';
    }

    function isModerator() {
      return currentRole() == 'moderator';
    }

    function isRegionLeader() {
      return currentRole() in ['consul', 'officer'];
    }

    function canManageAllianceList(regionId) {
      return ownerEmail() || currentRole() in ['admin', 'moderator'] || (currentRegionRole(regionId) in ['admin', 'moderator', 'consul'] && hasRegionAccess(regionId));
    }

    function canUseAdminPanel() {
      return ownerEmail() || isAdmin() || isModerator();
    }

    function canManageRegion(regionId) {
      return ownerEmail() || isAdmin() || isModerator() || (currentRegionRole(regionId) in ['admin', 'moderator', 'consul', 'officer'] && hasRegionAccess(regionId));
    }

    function canManageOwnAllianceColor(regionId, allianceId) {
      return signedIn()
        && currentRegionRole(regionId) == 'officer'
        && hasRegionAccess(regionId)
        && currentAlliance() == allianceId
        && currentRank() in ['p4', 'p5', 'r4', 'r5', '4', '5'];
    }

    function allianceColorWriteSafe(allianceId) {
      return request.resource.data.tag == allianceId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tag', 'colorHue', 'colorMode', 'colorUpdatedAt', 'colorUpdatedBy']);
    }

    function allianceColorCreateSafe(allianceId) {
      return request.resource.data.keys().hasOnly(['tag', 'colorHue', 'colorMode', 'colorUpdatedAt', 'colorUpdatedBy'])
        && request.resource.data.tag == allianceId;
    }

    function canDeleteWastelandRegistration(regionId) {
      return ownerEmail() || isAdmin() || isModerator() || (currentRegionRole(regionId) in ['admin', 'moderator', 'consul'] && hasRegionAccess(regionId));
    }

    function canAssignRole(role) {
      return ownerEmail()
        || (isAdmin() && role in ['moderator', 'consul', 'officer', 'player'])
        || (isModerator() && role in ['consul', 'officer', 'player']);
    }

    function roleIsSafeOnCreate() {
      return request.resource.data.role == 'player';
    }

    function ownerKeepsProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'createdAt', 'uid', 'email', 'providerId', 'regionAccess', 'allianceAccess', 'regionRoles']);
    }

    function ownerProfileUpdateSafe(userId) {
      return isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'lastLoginAt', 'updatedAt',
          'country', 'countryCode', 'regionAccess', 'allianceAccess', 'regionRoles',
          'profileComplete', 'gameNick', 'nickname', 'region', 'alliance', 'rank', 'shk',
          'gameProfile', 'farms', 'farmCount', 'activeFarmId', 'roleRequest', 'profileVisibility'
        ])
        && profileAccessFieldsSafe();
    }


    function ownerRegionRoleDowngradeSafe(userId) {
      return isOwner(userId)
        && resource.data.role in ['consul', 'officer']
        && request.resource.data.role == 'player'
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.gameProfile.region != resource.data.gameProfile.region
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'lastLoginAt', 'updatedAt',
          'country', 'countryCode', 'regionAccess', 'allianceAccess', 'regionRoles',
          'profileComplete', 'gameNick', 'nickname', 'region', 'alliance', 'rank', 'shk',
          'gameProfile', 'farms', 'farmCount', 'activeFarmId', 'roleRequest', 'role', 'roleLabel', 'profileVisibility'
        ])
        && profileAccessFieldsSafe();
    }

    function managerUpdateSafe() {
      return canUseAdminPanel()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && (!('providerId' in resource.data) || request.resource.data.providerId == resource.data.providerId)
        && canAssignRole(request.resource.data.role);
    }

    function requestableRole() {
      return request.resource.data.requestedRole in ['officer', 'consul']
        || (ownerEmail() && request.resource.data.requestedRole in ['admin', 'moderator']);
    }

    function ownerRoleRequestSafe(requestId) {
      return signedIn()
        && request.resource.data.uid == request.auth.uid
        && requestableRole()
        && request.resource.data.status in ['pending', 'cancelled'];
    }

    function ownerCanReadRoleRequest() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function publicPlayerSafe(userId) {
      return isOwner(userId)
        && request.resource.data.uid == userId
        && !('email' in request.resource.data)
        && request.resource.data.role == userDoc(userId).data.role
        && targetHasRegionAccess(userId, request.resource.data.region);
    }

    function managerPublicPlayerSafe() {
      return canUseAdminPanel()
        && !('email' in request.resource.data)
        && canAssignRole(request.resource.data.role);
    }

    function publicPlayerForRegionSafe(userId, regionId) {
      return isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.region == regionId
        && !('email' in request.resource.data)
        && request.resource.data.role == userDoc(userId).data.role
        && targetHasRegionAccess(userId, regionId);
    }

    function regionDoc(regionId) {
      return get(/databases/$(database)/documents/regions/$(regionId));
    }

    function regionFormOpen(regionId) {
      return exists(/databases/$(database)/documents/regions/$(regionId))
        && regionDoc(regionId).data.registrationForm.enabled == true;
    }

    function activeCycleMatches(regionId) {
      return request.resource.data.cycleId is string
        && request.resource.data.cycleId == regionDoc(regionId).data.registrationForm.currentCycleId;
    }

    function wastelandRegistrationFieldsSafe(regionId) {
      return regionFormOpen(regionId)
        && activeCycleMatches(regionId)
        && request.resource.data.region == regionId
        && request.resource.data.nickname is string
        && request.resource.data.alliance is string
        && request.resource.data.troopType is string
        && request.resource.data.shift is string
        && request.resource.data.shift in regionDoc(regionId).data.registrationForm.shifts;
    }


    function targetUserRegion(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? userDoc(userId).data.gameProfile.region
        : '';
    }

    function targetUserAlliance(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? userDoc(userId).data.gameProfile.alliance
        : '';
    }

    function targetHasRegionAccess(userId, regionId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && (userDoc(userId).data.gameProfile.region == regionId
          || (userDoc(userId).data.keys().hasAny(['regionAccess']) && regionId in userDoc(userId).data.regionAccess));
    }

    function hasAllianceAccess(regionId, allianceTag) {
      return currentUserExists()
        && allianceTag != ''
        && ((currentRegion() == regionId && currentAlliance() == allianceTag)
          || (currentUserDoc().data.keys().hasAny(['allianceAccess']) && (regionId + ':' + allianceTag) in currentUserDoc().data.allianceAccess));
    }

    function targetHasAllianceAccess(userId, regionId, allianceTag) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && allianceTag != ''
        && ((userDoc(userId).data.gameProfile.region == regionId && userDoc(userId).data.gameProfile.alliance == allianceTag)
          || (userDoc(userId).data.keys().hasAny(['allianceAccess']) && (regionId + ':' + allianceTag) in userDoc(userId).data.allianceAccess));
    }

    function canReadUser(userId) {
      return isOwner(userId)
        || canUseAdminPanel()
        || (currentRegionRole(targetUserRegion(userId)) in ['consul', 'officer'] && targetHasRegionAccess(userId, targetUserRegion(userId)));
    }

    function notificationTargetTypeSafe() {
      return request.resource.data.targetType in ['system', 'player', 'alliance', 'region', 'consuls', 'officers', 'admins', 'all'];
    }



    function statsChangeCreateSafe() {
      return signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'playerKey', 'changeType', 'source', 'processed', 'createdAt'])
        && request.resource.data.uid is string
        && request.resource.data.playerKey is string
        && request.resource.data.changeType in ['profile_changed', 'farm_changed', 'role_changed', 'admin_changed', 'sync_changed']
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 32
        && request.resource.data.processed == false
        && request.resource.data.createdAt == request.time
        && (request.resource.data.uid == request.auth.uid || canUseAdminPanel());
    }

    function optionalReplyFieldsSafe() {
      return (!('replyToId' in request.resource.data) || (request.resource.data.replyToId is string && request.resource.data.replyToId.size() <= 120))
        && (!('replyToTitle' in request.resource.data) || (request.resource.data.replyToTitle is string && request.resource.data.replyToTitle.size() <= 160))
        && (!('replyToActorName' in request.resource.data) || (request.resource.data.replyToActorName is string && request.resource.data.replyToActorName.size() <= 120))
        && (!('replyToCreatedAtMs' in request.resource.data) || request.resource.data.replyToCreatedAtMs is int);
    }

    function ownerMessageStateUpdateSafe(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'readAtMs', 'unread', 'archived'])
        && (!('unread' in request.resource.data) || request.resource.data.unread is bool)
        && (!('archived' in request.resource.data) || request.resource.data.archived is bool)
        && (!('readAtMs' in request.resource.data) || request.resource.data.readAtMs is int);
    }

    function notificationCreateSafe(userId) {
      return signedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.type is string
        && request.resource.data.type in ['notice', 'profile_changed', 'farm_profile_changed', 'registration_submitted', 'role_approved', 'site_message']
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 160
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 600
        && request.resource.data.region is string
        && request.resource.data.alliance is string
        && request.resource.data.actorName is string
        && request.resource.data.actorName.size() <= 120
        && request.resource.data.actorRole is string
        && request.resource.data.actorRole in ['admin', 'moderator', 'consul', 'officer', 'player']
        && request.resource.data.actorRoleText is string
        && request.resource.data.actorRoleText.size() <= 80
        && request.resource.data.actorPhotoURL is string
        && request.resource.data.actorPhotoURL.size() <= 300
        && request.resource.data.targetType is string
        && notificationTargetTypeSafe()
        && request.resource.data.targetLabel is string
        && request.resource.data.targetLabel.size() <= 160
        && optionalReplyFieldsSafe()
        && request.resource.data.createdAtMs is int
        && request.resource.data.unread == true
        && !request.resource.data.keys().hasAny(['email', 'toEmail'])
        && request.resource.data.keys().hasOnly(['type','title','message','region','alliance','actorUid','actorName','actorRole','actorRoleText','actorPhotoURL','targetType','targetLabel','replyToId','replyToTitle','replyToActorName','replyToCreatedAtMs','createdAt','createdAtMs','unread']);
    }

    function messageActorRoleSafe() {
      return request.resource.data.type != 'site_message'
        || request.resource.data.actorRole == currentRegionRole(request.resource.data.region);
    }

    function ownerNotificationUpdateSafe(userId) {
      return ownerMessageStateUpdateSafe(userId);
    }

    function selfNotificationCreateSafe(userId) {
      return isOwner(userId)
        && notificationCreateSafe(userId)
        && request.resource.data.type in ['notice', 'profile_changed', 'farm_profile_changed', 'registration_submitted', 'role_approved', 'site_message'];
    }

    function canMessageTarget(userId) {
      return notificationCreateSafe(userId)
        && messageActorRoleSafe()
        && (
          ownerEmail() || isAdmin() || isModerator()
          || (currentRegionRole(request.resource.data.region) in ['consul', 'officer'] && request.resource.data.region != '' && hasRegionAccess(request.resource.data.region) && targetHasRegionAccess(userId, request.resource.data.region))
          || (request.resource.data.region != '' && request.resource.data.alliance != '' && hasRegionAccess(request.resource.data.region) && hasAllianceAccess(request.resource.data.region, request.resource.data.alliance) && targetHasAllianceAccess(userId, request.resource.data.region, request.resource.data.alliance))
        );
    }


    function sentMessageCreateSafe(userId) {
      return isOwner(userId)
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.type == 'sent_message'
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 160
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 600
        && request.resource.data.region is string
        && request.resource.data.alliance is string
        && request.resource.data.targetType is string
        && request.resource.data.targetType in ['player', 'alliance', 'region', 'consuls', 'officers', 'admins', 'all']
        && request.resource.data.targetLabel is string
        && request.resource.data.targetLabel.size() <= 160
        && request.resource.data.recipientCount is int
        && request.resource.data.recipientCount >= 0
        && request.resource.data.recipientCount <= 500
        && request.resource.data.recipientPreview is string
        && request.resource.data.recipientPreview.size() <= 300
        && optionalReplyFieldsSafe()
        && request.resource.data.createdAtMs is int
        && request.resource.data.archived == false
        && !request.resource.data.keys().hasAny(['email', 'toEmail'])
        && request.resource.data.keys().hasOnly(['type','title','message','region','alliance','targetType','targetLabel','recipientCount','recipientPreview','replyToId','replyToTitle','replyToActorName','replyToCreatedAtMs','actorUid','createdAt','createdAtMs','archived']);
    }

    function ownerSentMessageUpdateSafe(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['archived'])
        && (!('archived' in request.resource.data) || request.resource.data.archived is bool);
    }

    function publicWastelandRegistrationSafe(regionId) {
      return wastelandRegistrationFieldsSafe(regionId)
        && request.resource.data.publicLink == true;
    }

    function signedWastelandRegistrationSafe(regionId, registrationId) {
      return signedIn()
        && wastelandRegistrationFieldsSafe(regionId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdByAuth == true;
    }

    function nicknameLockFieldsSafe(regionId) {
      return request.resource.data.keys().hasOnly([
          'region', 'cycleId', 'nickname', 'nickKey', 'registrationId', 'ownerUid', 'farmId',
          'createdByAuth', 'publicLink', 'source', 'createdAt', 'createdAtMs', 'updatedAt', 'updatedAtMs'
        ])
        && request.resource.data.region == regionId
        && request.resource.data.cycleId is string
        && request.resource.data.cycleId.size() > 0
        && request.resource.data.cycleId.size() <= 120
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 120
        && request.resource.data.nickKey is string
        && request.resource.data.nickKey.size() > 0
        && request.resource.data.nickKey.size() <= 160
        && request.resource.data.registrationId is string
        && request.resource.data.registrationId.size() > 0
        && request.resource.data.registrationId.size() <= 180
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid.size() <= 160
        && request.resource.data.farmId is string
        && request.resource.data.farmId.size() <= 80
        && request.resource.data.createdByAuth is bool
        && request.resource.data.publicLink is bool;
    }

    function signedNicknameLockCreateSafe(regionId) {
      return signedIn()
        && nicknameLockFieldsSafe(regionId)
        && request.resource.data.createdByAuth == true
        && request.resource.data.ownerUid == request.auth.uid;
    }

    function publicNicknameLockCreateSafe(regionId) {
      return nicknameLockFieldsSafe(regionId)
        && request.resource.data.publicLink == true
        && request.resource.data.createdByAuth == false
        && request.resource.data.ownerUid == '';
    }


    function notificationSummaryFieldsSafe() {
      return request.resource.data.keys().hasOnly([
          'unreadTotal', 'lastTitle', 'lastMessage', 'lastRegion', 'lastAlliance',
          'lastActorUid', 'lastActorName', 'lastActorRole', 'lastTargetType',
          'lastNotificationAt', 'lastNotificationAtMs', 'updatedAt', 'updatedAtMs'
        ])
        && (!request.resource.data.keys().hasAny(['unreadTotal']) || (request.resource.data.unreadTotal is int && request.resource.data.unreadTotal >= 0 && request.resource.data.unreadTotal <= 99999))
        && (!request.resource.data.keys().hasAny(['lastTitle']) || (request.resource.data.lastTitle is string && request.resource.data.lastTitle.size() <= 160))
        && (!request.resource.data.keys().hasAny(['lastMessage']) || (request.resource.data.lastMessage is string && request.resource.data.lastMessage.size() <= 300))
        && (!request.resource.data.keys().hasAny(['lastRegion']) || (request.resource.data.lastRegion is string && request.resource.data.lastRegion.size() <= 20))
        && (!request.resource.data.keys().hasAny(['lastAlliance']) || (request.resource.data.lastAlliance is string && request.resource.data.lastAlliance.size() <= 3))
        && (!request.resource.data.keys().hasAny(['lastActorUid']) || (request.resource.data.lastActorUid is string && request.resource.data.lastActorUid.size() <= 160))
        && (!request.resource.data.keys().hasAny(['lastActorName']) || (request.resource.data.lastActorName is string && request.resource.data.lastActorName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['lastActorRole']) || (request.resource.data.lastActorRole in ['admin', 'moderator', 'consul', 'officer', 'player']))
        && (!request.resource.data.keys().hasAny(['lastTargetType']) || (request.resource.data.lastTargetType in ['system', 'player', 'alliance', 'region', 'consuls', 'officers', 'admins', 'all']))
        && (!request.resource.data.keys().hasAny(['lastNotificationAtMs']) || request.resource.data.lastNotificationAtMs is int)
        && (!request.resource.data.keys().hasAny(['updatedAtMs']) || request.resource.data.updatedAtMs is int);
    }

    function notificationSummaryWriteSafe(userId) {
      return notificationSummaryFieldsSafe()
        && (
          isOwner(userId)
          || ownerEmail()
          || isAdmin()
          || (signedIn()
            && request.resource.data.keys().hasAny(['lastActorUid'])
            && request.resource.data.lastActorUid == request.auth.uid)
        );
    }

    match /users/{userId} {
      allow create: if ownerEmail() || (isOwner(userId) && roleIsSafeOnCreate());
      allow read: if canReadUser(userId);
      allow update: if ownerEmail() || managerUpdateSafe() || ownerProfileUpdateSafe(userId) || ownerRegionRoleDowngradeSafe(userId) || (isOwner(userId) && ownerKeepsProtectedFields());
      allow delete: if ownerEmail() || isAdmin();

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || ownerEmail() || isAdmin();
        allow update: if ownerNotificationUpdateSafe(userId) || ownerEmail() || isAdmin();
        allow delete: if isOwner(userId) || ownerEmail() || isAdmin();
        allow create: if selfNotificationCreateSafe(userId) || canMessageTarget(userId);
      }

      match /notificationMeta/{metaId} {
        allow read: if isOwner(userId) || ownerEmail() || isAdmin();
        allow create, update: if notificationSummaryWriteSafe(userId);
        allow delete: if ownerEmail() || isAdmin();
      }


      match /sentMessages/{messageId} {
        allow read: if isOwner(userId) || ownerEmail() || isAdmin();
        allow update: if ownerSentMessageUpdateSafe(userId) || ownerEmail() || isAdmin();
        allow delete: if isOwner(userId) || ownerEmail() || isAdmin();
        allow create: if sentMessageCreateSafe(userId);
      }
    }

    match /publicPlayers/{userId} {
      allow read: if true;
      allow create, update: if ownerEmail() || managerPublicPlayerSafe() || publicPlayerSafe(userId);
      allow delete: if ownerEmail() || isAdmin();
    }


    match /statsChanges/{changeId} {
      allow create: if statsChangeCreateSafe();
      allow read, update, delete: if ownerEmail() || isAdmin() || isModerator();
    }

    match /statsIndex/{playerKey} {
      allow read, write: if ownerEmail() || isAdmin() || isModerator();
    }

    match /statsMeta/{docId} {
      allow read: if true;
      allow write: if ownerEmail() || isAdmin() || isModerator();
    }

    match /roleRequests/{requestId} {
      allow create: if ownerEmail() || ownerRoleRequestSafe(requestId) || canReviewRoleRequests();
      allow read: if ownerCanReadRoleRequest() || canReviewRoleRequests();
      allow update: if ownerEmail() || ownerRoleRequestSafe(requestId) || canReviewRoleRequests();
      allow delete: if ownerEmail() || isAdmin();
    }

    match /regions/{regionId} {
      allow read: if true;
      allow create, update: if canManageRegion(regionId);
      allow delete: if ownerEmail() || isAdmin();

      match /alliances/{allianceId} {
        allow read: if true;
        allow create: if canManageAllianceList(regionId) || (canManageOwnAllianceColor(regionId, allianceId) && allianceColorCreateSafe(allianceId));
        allow update: if canManageAllianceList(regionId) || (canManageOwnAllianceColor(regionId, allianceId) && allianceColorWriteSafe(allianceId));
        allow delete: if canManageAllianceList(regionId);
      }

      match /privateSettings/{settingId} {
        allow read, create, update, delete: if canManageRegion(regionId);
      }

      match /players/{userId} {
        allow read: if hasRegionAccess(regionId) || canManageRegion(regionId);
        allow create, update: if ownerEmail() || managerPublicPlayerSafe() || publicPlayerForRegionSafe(userId, regionId);
        allow delete: if canManageRegion(regionId) || isOwner(userId);
      }

      match /wastelandRegistrations/{registrationId} {
        allow read: if hasRegionAccess(regionId) || canManageRegion(regionId);
        allow create: if ownerEmail() || canManageRegion(regionId) || signedWastelandRegistrationSafe(regionId, registrationId) || publicWastelandRegistrationSafe(regionId);
        allow update: if ownerEmail() || canManageRegion(regionId);
        allow delete: if canDeleteWastelandRegistration(regionId);
      }

      match /nicknameLocks/{lockId} {
        allow get: if true;
        allow list: if false;
        allow create: if ownerEmail() || canManageRegion(regionId) || signedNicknameLockCreateSafe(regionId) || publicNicknameLockCreateSafe(regionId);
        allow update: if ownerEmail() || canManageRegion(regionId);
        allow delete: if canDeleteWastelandRegistration(regionId);
      }

      match /wastelandTowerPlans/{planId} {
        allow read: if hasRegionAccess(regionId) || canManageRegion(regionId);
        allow create, update: if canManageRegion(regionId);
        allow delete: if canManageRegion(regionId);
      }

      match /actionLogs/{logId} {
        allow read: if ownerEmail() || isAdmin() || isModerator()
          || (currentRegionRole(regionId) == 'consul' && hasRegionAccess(regionId))
          || (currentRegionRole(regionId) == 'officer' && hasRegionAccess(regionId) && (resource.data.alliance == currentAlliance() || resource.data.actorAlliance == currentAlliance()));
        allow create: if signedIn() && (hasRegionAccess(regionId) || canManageRegion(regionId));
        allow update, delete: if ownerEmail() || isAdmin();
      }
    }

    match /shortRegionLinks/{code} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.region is string
        && canManageRegion(request.resource.data.region);
      allow delete: if signedIn()
        && resource.data.region is string
        && canManageRegion(resource.data.region);
    }

    match /regionTableShares/{code} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.region is string
        && canManageRegion(request.resource.data.region);
      allow delete: if signedIn()
        && resource.data.region is string
        && canManageRegion(resource.data.region);
    }

    match /finalPlanShares/{code} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.region is string
        && canManageRegion(request.resource.data.region);
      allow delete: if signedIn()
        && resource.data.region is string
        && canManageRegion(resource.data.region);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
